DATABASE_URL=postgresql:///financial_rag
SEC_USER_AGENT=YueLiang liangyue3666@gmail.com
SEC_DOWNLOAD_DIR=./data/sec_filings
LOG_LEVEL=INFO
LOG_FILE=./pipeline.log

# --- LLM (HPC SGLang endpoint via ngrok — backend-only, never exposed) ---
# Update this each time the HPC ngrok tunnel rotates, then restart retrieval:
#   docker compose up -d retrieval
SGLANG_BASE_URL=
SGLANG_MODEL=Qwen/Qwen3-8B
SGLANG_API_KEY=
SGLANG_MAX_TOKENS=32768

# --- Public /chat endpoint auth ---
# Empty = auth disabled (dev). Set to a shared secret to require X-API-Key header.
API_KEY=

# --- CORS for the frontend ---
# "*" or a comma-separated list of allowed origins (e.g. http://localhost:3000)
CORS_ORIGINS=*

# --- CLI helper (rag_chat.py) ---
# Override only if the RAG service is not on localhost:8000
# RAG_URL=http://localhost:8000
